# Neon — cadena de conexión (Project → Connection string)
DATABASE_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Web Push — genera con: npm run generate:vapid
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contacto para el proveedor push (debe ser mailto: o https:)
VAPID_SUBJECT_MAIL=mailto:tu@email.com

# Opcional: Vercel añade CRON_SECRET al invocar el cron; define el mismo en Environment Variables
CRON_SECRET=
